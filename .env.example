# 开发环境变量模板
# 复制此文件为 .env 后填入实际值

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=13306

# Redis
REDIS_PORT=6379

# Nacos
NACOS_PORT=8848
NACOS_GRPC_PORT=9848

# Gateway
GATEWAY_PORT=8080

# 微服务端口
USER_SERVICE_PORT=8081
WORD_SERVICE_PORT=8082
CHAT_SERVICE_PORT=8083
WRITING_SERVICE_PORT=8084
TRANSLATE_SERVICE_PORT=8085
FORUM_SERVICE_PORT=8086

# Nginx
NGINX_PORT=80

# JWT 密钥（生产环境必须更换）
JWT_SECRET=your-jwt-secret-key-change-in-production

# AI 服务（根据实际使用的 AI 提供商配置）
# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 翻译服务
DEEPL_API_KEY=

# 语音服务
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# OSS 文件存储
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_ENDPOINT=
